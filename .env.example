# Database
DATABASE_URL=postgresql://vibeuser:PASSWORD@db:5432/vibecommunity
POSTGRES_USER=vibeuser
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=vibecommunity

# NextAuth
NEXTAUTH_URL=https://vibecodingcommunity.ir
NEXTAUTH_SECRET=generate-a-secure-secret-with-openssl-rand-base64-32

# SMS.ir (Iranian SMS Service)
SMSIR_API_KEY=your_smsir_api_key
SMSIR_MESSAGE_ID=your_smsir_message_id

# App Config
NODE_ENV=production
