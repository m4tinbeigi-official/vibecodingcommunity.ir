// Prisma Schema for Vibe Coding Community

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model
model User {
  id              String    @id @default(cuid())
  name            String?   // Legacy field, kept for compatibility
  email           String?   @unique
  phone           String?   @unique
  emailVerified   DateTime?
  image           String?   // Legacy avatar field
  role            String    @default("user")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Profile basic info
  firstName       String?
  lastName        String?
  displayName     String?
  username        String?   @unique
  avatarUrl       String?
  coverUrl        String?
  city            String?
  bio             String?   @db.Text
  telegramLink    String?
  linkedinLink    String?
  githubLink      String?
  websiteLink     String?

  // Professional info
  mainField       String?
  secondaryFields String[]  @default([])
  experienceLevel String?
  tools           String[]  @default([])
  skills          String[]  @default([])

  // Goals and collaboration
  membershipGoals String[]  @default([])
  collaborationStatus String?

  // Privacy settings
  showEmail       Boolean   @default(false)
  showPhone       Boolean   @default(false)
  showSocialLinks Boolean   @default(true)
  profilePublic   Boolean   @default(true)

  // Onboarding
  onboardingCompleted Boolean @default(false)
  onboardingStep   Int       @default(1)

  // Gamification (placeholder)
  points          Int       @default(0)
  level           Int       @default(1)

  accounts        Account[]
  sessions        Session[]
}

// NextAuth Account
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// NextAuth Session
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// VerificationToken
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// OTP for phone verification
model PhoneOTP {
  id         String   @id @default(cuid())
  phoneNumber String
  otpHash    String
  expiresAt  DateTime
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([phoneNumber, expiresAt])
}

// Rate limiting for OTP
model RateLimit {
  id         String   @id @default(cuid())
  identifier String   // IP or phone number
  action     String   // 'send_otp', 'verify_otp'
  count      Int      @default(1)
  windowStart DateTime @default(now())

  @@unique([identifier, action, windowStart])
  @@index([identifier, action])
}
